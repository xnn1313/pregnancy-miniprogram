/* app.wxss */
page {
  background-color: #f8f8f8;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

.container {
  padding: 20rpx;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.text-primary {
  color: #FF6B9D;
}

.btn-primary {
  background: #FF6B9D;
  color: #fff;
  border-radius: 40rpx;
  padding: 20rpx;
  text-align: center;
}