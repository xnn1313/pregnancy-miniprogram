<!--pages/recipe/detail.wxml-->
<view class="container" wx:if="{{recipe}}">
  <!-- 头部 -->
  <view class="header">
    <text class="name">{{recipe.name}}</text>
    <view class="meta">
      <text>{{recipe.category}}</text>
      <text>{{recipe.prep_time}}分钟</text>
      <text>{{recipe.difficulty}}</text>
    </view>
  </view>

  <!-- 益处 -->
  <view class="section">
    <text class="section-title">孕期益处</text>
    <view class="tags">
      <text class="tag" wx:for="{{recipe.benefits}}" wx:key="*this">{{item}}</text>
    </view>
  </view>

  <!-- 营养亮点 -->
  <view class="section">
    <text class="section-title">关键营养</text>
    <view class="nutrition-grid">
      <view class="nut-item" wx:for="{{recipe.nutrition_highlight}}" wx:for-index="key" wx:for-item="val" wx:key="key">
        <text class="nut-value">{{val}}</text>
        <text class="nut-name">{{key}}</text>
      </view>
    </view>
  </view>

  <!-- 食材 -->
  <view class="section">
    <text class="section-title">食材清单</text>
    <view class="ingredient-list">
      <view class="ingredient" wx:for="{{recipe.ingredients}}" wx:key="name">
        <text class="ing-name">{{item.name}}</text>
        <text class="ing-amount">{{item.amount}}{{item.unit || 'g'}}</text>
      </view>
    </view>
  </view>

  <!-- 步骤 -->
  <view class="section">
    <text class="section-title">制作步骤</text>
    <view class="steps">
      <view class="step" wx:for="{{recipe.steps}}" wx:key="index">
        <text class="step-num">{{index + 1}}</text>
        <text class="step-text">{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 警告 -->
  <view class="warning" wx:if="{{recipe.warnings && recipe.warnings.length > 0}}">
    <text class="warning-title">⚠️ 注意事项</text>
    <text wx:for="{{recipe.warnings}}" wx:key="*this">{{item}}</text>
  </view>

  <!-- 底部操作 -->
  <view class="bottom-bar">
    <button class="btn-done" bindtap="markDone">标记已做</button>
    <button class="btn-fav" bindtap="toggleFavorite">收藏</button>
  </view>
</view>