/* pages/login/login.wxss */
.login-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
}
.logo {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}
.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #FF6B9D;
}
.subtitle {
  color: #999;
  margin: 20rpx 0 60rpx;
}
.btn-primary {
  width: 80%;
  margin-top: 40rpx;
}