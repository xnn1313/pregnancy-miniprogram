/* pages/record/chart.wxss */
.header {
  padding: 40rpx;
  background: linear-gradient(135deg, #FF6B9D 0%, #FFB6C1 100%);
  color: white;
  text-align: center;
}
.title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
}
.subtitle {
  font-size: 26rpx;
  opacity: 0.9;
  margin-top: 8rpx;
}
.stats {
  display: flex;
  background: white;
  margin: -30rpx 20rpx 20rpx;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.1);
}
.stat-item {
  flex: 1;
  text-align: center;
}
.stat-value {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #FF6B9D;
}
.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}
.chart-placeholder {
  background: white;
  margin: 20rpx;
  padding: 80rpx;
  border-radius: 20rpx;
  text-align: center;
  color: #999;
}
.hint {
  display: block;
  font-size: 24rpx;
  margin-top: 16rpx;
  color: #ccc;
}
.weight-list {
  background: white;
  margin: 20rpx;
  border-radius: 20rpx;
  padding: 20rpx;
}
.weight-item {
  display: flex;
  justify-content: space-between;
  padding: 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}
.weight-item:last-child {
  border-bottom: none;
}
.date {
  color: #666;
}
.weight {
  font-weight: bold;
  color: #FF6B9D;
}