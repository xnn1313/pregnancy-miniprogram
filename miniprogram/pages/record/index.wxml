<!--pages/record/index.wxml-->
<view class="container">
  <view class="date">{{today}}</view>
  
  <!-- 体重 -->
  <view class="card">
    <text class="label">体重 (kg)</text>
    <input class="weight-input" type="digit" placeholder="请输入" value="{{weight}}" bindinput="onWeight" />
  </view>

  <!-- 症状 -->
  <view class="card">
    <text class="label">今日症状</text>
    <view class="symptom-list">
      <view class="symptom {{symptoms.indexOf(s)>-1?'active':''}}" 
            wx:for="{{symptomOptions}}" wx:for-item="s" wx:key="*this"
            bindtap="toggleSymptom" data-symptom="{{s}}">{{s}}</view>
    </view>
  </view>

  <!-- 心情 -->
  <view class="card">
    <text class="label">今日心情</text>
    <view class="mood-list">
      <view class="mood {{mood===m.value?'active':''}}" 
            wx:for="{{moods}}" wx:for-item="m" wx:key="value"
            bindtap="setMood" data-mood="{{m.value}}">{{m.emoji}}</view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <button class="btn-save" bindtap="save">保存记录</button>
  <button class="btn-chart" bindtap="goChart">查看体重趋势</button>
</view>