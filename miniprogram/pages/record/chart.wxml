<!--pages/record/chart.wxml-->
<view class="container">
  <view class="header">
    <text class="title">体重趋势</text>
    <text class="subtitle">近30天变化</text>
  </view>

  <view class="stats">
    <view class="stat-item">
      <text class="stat-value">{{avgWeight}}</text>
      <text class="stat-label">平均体重(kg)</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{maxWeight}}</text>
      <text class="stat-label">最高(kg)</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{minWeight}}</text>
      <text class="stat-label">最低(kg)</text>
    </view>
  </view>

  <view class="chart-placeholder">
    <text>📊 图表开发中...</text>
    <text class="hint">后续版本将支持可视化图表</text>
  </view>

  <view class="weight-list">
    <view class="weight-item" wx:for="{{weights}}" wx:key="date">
      <text class="date">{{item.date}}</text>
      <text class="weight">{{item.weight}} kg</text>
    </view>
  </view>
</view>