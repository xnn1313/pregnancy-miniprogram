/* pages/record/index.wxss */
.date {
  text-align: center;
  padding: 30rpx;
  color: #666;
  font-size: 28rpx;
}
.card {
  background: white;
  margin: 20rpx;
  padding: 30rpx;
  border-radius: 20rpx;
}
.label {
  font-size: 30rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 20rpx;
}
.weight-input {
  width: 100%;
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  font-size: 32rpx;
}
.symptom-list, .mood-list {
  display: flex;
  flex-wrap: wrap;
}
.symptom {
  padding: 16rpx 32rpx;
  margin: 10rpx;
  border-radius: 30rpx;
  background: #f5f5f5;
  font-size: 28rpx;
}
.symptom.active {
  background: #FF6B9D;
  color: white;
}
.mood {
  font-size: 60rpx;
  padding: 20rpx;
  margin: 10rpx;
  border-radius: 50%;
}
.mood.active {
  background: #FFE4E9;
}
.btn-save {
  margin: 40rpx 20rpx;
  background: #FF6B9D;
  color: white;
  border-radius: 40rpx;
}
.btn-chart {
  margin: 20rpx;
  background: white;
  color: #FF6B9D;
  border: 2rpx solid #FF6B9D;
  border-radius: 40rpx;
}