/* pages/record/index.wxss */
.date {
  text-align: center;
  color: #999;
  margin-bottom: 20rpx;
}
.record-item {
  display: flex;
  flex-direction: column;
}
.label {
  font-weight: bold;
  margin-bottom: 16rpx;
}
.symptom-list, .mood-list {
  display: flex;
  flex-wrap: wrap;
}
.symptom, .mood {
  padding: 10rpx 20rpx;
  margin: 8rpx;
  border-radius: 30rpx;
  background: #f5f5f5;
}
.symptom.active {
  background: #FF6B9D;
  color: #fff;
}
.mood.active {
  background: #FFE4E9;
}
.mood {
  font-size: 40rpx;
}