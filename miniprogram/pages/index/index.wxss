/* pages/index/index.wxss */
.pregnancy-info {
  display: flex;
  align-items: baseline;
}
.week {
  font-size: 48rpx;
  font-weight: bold;
  color: #FF6B9D;
}
.stage {
  margin-left: 16rpx;
  color: #999;
}
.due-date {
  margin-top: 16rpx;
  color: #666;
}
.section-title {
  font-size: 32rpx;
  font-weight: bold;
