/* pages/mine/index.wxss */
.user-card {
  display: flex;
  align-items: center;
  padding: 40rpx;
  background: linear-gradient(135deg, #FF6B9D 0%, #FFB6C1 100%);
  color: white;
}
.avatar {
  width: 120rpx;
  height: 120rpx;
  background: white;
  border-radius: 50%;
  font-size: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.info {
  margin-left: 30rpx;
}
.name {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
}
.role {
  font-size: 26rpx;
  opacity: 0.9;
  margin-top: 8rpx;
}
.menu {
  background: white;
  margin: 20rpx;
  border-radius: 20rpx;
  overflow: hidden;
}
.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}
.menu-item:last-child {
  border-bottom: none;
}
.menu-item .icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}
.menu-item .text {
  flex: 1;
  font-size: 30rpx;
}
.menu-item .arrow {
  color: #ccc;
  font-size: 36rpx;
}
.btn-logout {
  margin: 60rpx 40rpx;
  background: white;
  color: #FF6B9D;
  border: 2rpx solid #FF6B9D;
  border-radius: 40rpx;
}