<!--pages/mine/index.wxml-->
<view class="container">
  <view class="user-card card">
    <image class="avatar" src="/static/avatar.png" mode="aspectFill" />
    <view class="info">
      <text class="name">{{user.name || '未登录'}}</text>
      <text class="role">{{user.role==='owner'?'孕妈妈':'准爸爸'}}</text>
    </view>
  </view>

  <view class="menu card">
    <view class="menu-item" bindtap="goArchive">
      <text>孕期档案</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goMembers">
      <text>家庭成员</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goSettings">
      <text>提醒设置</text>
      <text class="arrow">›</text>
    </view>
  </view>
</view>