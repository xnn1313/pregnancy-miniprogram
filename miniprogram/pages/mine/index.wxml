<!--pages/mine/index.wxml-->
<view class="container">
  <!-- 用户卡片 -->
  <view class="user-card">
    <view class="avatar">🤰</view>
    <view class="info">
      <text class="name">{{user.name || '未登录'}}</text>
      <text class="role">{{user.role==='owner'?'孕妈妈':'准爸爸'}}</text>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu">
    <view class="menu-item" bindtap="goArchive">
      <text class="icon">📋</text>
      <text class="text">孕期档案</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goMembers">
      <text class="icon">👨‍👩‍👧</text>
      <text class="text">家庭成员</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goFavorites">
      <text class="icon">❤️</text>
      <text class="text">我的收藏</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goSettings">
      <text class="icon">🔔</text>
      <text class="text">提醒设置</text>
      <text class="arrow">›</text>
    </view>
  </view>

  <!-- 退出按钮 -->
  <button class="btn-logout" wx:if="{{isLoggedIn}}" bindtap="logout">退出登录</button>
</view>